rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    // ZERO-TRUST FIRESTORE RULES — IronCore Fit
    // ════════════════════════════════════════════════════════════════
    //
    // PRINCIPLES:
    //   1. Deny by default — every path must have an explicit allow
    //   2. Owner-only for private data — users can only read/write their own
    //   3. Server-authoritative for game state — XP, league, Elo, battles
    //   4. Field-level protection — subscription/isPremium are server-only
    //   5. Guild leader validation — only owners/leaders can modify guild data
    //   6. Type + size validation on all user-writable paths
    //
    // IMPORTANT: Cloud Functions use Admin SDK and bypass all rules.
    // These rules ONLY govern client-side reads/writes.
    // ════════════════════════════════════════════════════════════════

    // ── Helper Functions ──────────────────────────────────────────

    // Caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Caller owns this userId path
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Server-protected fields that clients MUST NOT write
    function serverOnlyFields() {
      return ['subscription', 'isPremium', 'elo', 'eloRating',
              'leaguePoints', 'verifiedXp', 'verifiedLevel',
              'ironScore', 'weeklyXpContribution', 'forgeShields',
              'weightStatus', 'lastDecayApplied', 'lastWeightAssessment'].toSet();
    }

    // Check that no server-only fields are being created
    function noServerFieldsOnCreate() {
      return !request.resource.data.keys().hasAny(serverOnlyFields());
    }

    // Check that no server-only fields are being modified on update
    function noServerFieldsOnUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(serverOnlyFields());
    }

    // String validation
    function isValidString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    // Number within range
    function isValidNumber(val, min, max) {
      return val is number && val >= min && val <= max;
    }

    // Timestamp validation (within last 5 minutes to prevent backdating)
    function isRecentTimestamp(val) {
      return val is timestamp && val <= request.time;
    }

    // Max document size guard (estimated field count)
    function hasReasonableFieldCount() {
      return request.resource.data.keys().size() <= 100;
    }


    // ══════════════════════════════════════════════════════════════
    // 1. USER DATA — Private, owner-only
    // ══════════════════════════════════════════════════════════════

    // Top-level user document
    // Contains: username, level, xp, league, wins, losses, streak, etc.
    // Server-protected: subscription, isPremium, elo, eloRating, leaguePoints
    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
                    && noServerFieldsOnCreate()
                    && hasReasonableFieldCount();

      allow update: if isOwner(userId)
                    && noServerFieldsOnUpdate()
                    && hasReasonableFieldCount();

      allow delete: if isOwner(userId);

      // ── User profile subcollection ──
      // users/{uid}/data/profile — biometric data, goals, settings, identity
      match /data/profile {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableFieldCount();
        allow update: if isOwner(userId) && hasReasonableFieldCount();
        allow delete: if isOwner(userId);
      }

      // ── Other user data subcollections ──
      // users/{uid}/data/{docId} — meals, workouts, burned, progress, etc.
      // Excludes "profile" (handled above with stricter rules)
      match /data/{docId} {
        allow read: if isOwner(userId) && docId != "profile";
        allow write: if isOwner(userId)
                     && docId != "profile"
                     && hasReasonableFieldCount();
      }

      // ── Inbox — DM system ──
      // Owner can read all their DMs. Any authenticated user can SEND a DM
      // (create) but must stamp their own userId as fromId (no spoofing).
      // Owner can mark messages as read (update). Owner can delete.
      match /inbox/{docId} {
        allow read: if isOwner(userId);

        // Anyone can send a DM, but fromId must match their auth
        allow create: if isAuth()
                      && request.resource.data.fromId == request.auth.uid
                      && isValidString(request.resource.data.fromId, 128)
                      && request.resource.data.keys().size() <= 20;

        // Only inbox owner can mark as read
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['read', 'readAt']);

        allow delete: if isOwner(userId);
      }

      // ── Weight progress entries — server-only writes ──
      // All weight entries go through the logWeightEntry Cloud Function.
      // Clients can read their own progress but NEVER write directly.
      match /progress/{entryId} {
        allow read: if isOwner(userId);
        allow write: if false; // Server-only via Admin SDK (logWeightEntry function)
      }

      // ── Following, notifications, photos — owner only ──
      match /{subcollection}/{docId} {
        allow read: if isOwner(userId)
                    && subcollection != "data"
                    && subcollection != "inbox"
                    && subcollection != "progress";
        allow write: if isOwner(userId)
                     && subcollection != "data"
                     && subcollection != "inbox"
                     && subcollection != "progress"
                     && hasReasonableFieldCount();
      }
    }


    // ══════════════════════════════════════════════════════════════
    // USERNAME REGISTRY — Write-once uniqueness index
    // ══════════════════════════════════════════════════════════════
    // Anyone can check if a username is taken (read).
    // Only authenticated users can claim an unclaimed username (create).
    // Once claimed, a username cannot be updated or deleted.
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.uid == request.auth.uid
                    && isValidString(request.resource.data.uid, 128);
      allow update, delete: if false;
    }


    // ══════════════════════════════════════════════════════════════
    // 2. LEADERBOARD — Read-only from client
    // ══════════════════════════════════════════════════════════════
    // Leaderboard entries are SERVER-AUTHORITATIVE.
    // Only Cloud Functions (Admin SDK) write leaderboard data.
    // This prevents XP/level spoofing from the client.
    match /leaderboard/{entryId} {
      allow read: if isAuth();
      allow write: if false; // Server-only via Admin SDK
    }


    // ══════════════════════════════════════════════════════════════
    // 3. BATTLES — Server-authoritative PvP
    // ══════════════════════════════════════════════════════════════
    // Battle creation: challenger can create (stamps own userId).
    // Battle acceptance/decline: opponent can update status to 'accepted'/'declined'.
    // Battle completion: SERVER-ONLY — anti-cheat validates workout data
    //   and determines the winner. No client can set winnerId or XP awards.
    match /battles/{battleId} {
      allow read: if isAuth();

      // Challenger creates the battle, must stamp their own userId
      allow create: if isAuth()
                    && request.resource.data.challenger.userId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.winnerId == null
                    && !('xpReward' in request.resource.data);

      // Only the OPPONENT can accept or decline a pending battle.
      // They can ONLY change status to 'accepted' or 'declined'.
      // They CANNOT set winnerId, XP, or any game-state fields.
      allow update: if isAuth()
                    && resource.data.status == 'pending'
                    && resource.data.opponent.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'acceptedAt', 'declinedAt'])
                    && (request.resource.data.status == 'accepted'
                        || request.resource.data.status == 'declined');

      // Battle completion (setting winnerId, XP) is SERVER-ONLY
      // Deletion is never allowed
      allow delete: if false;
    }

    // ── Battle workout submissions ──
    // Players submit their workout data to a subcollection.
    // Each player can only write ONCE (their own submission).
    // The server Cloud Function reads both submissions to determine winner.
    match /battles/{battleId}/submissions/{odId} {
      allow read: if isAuth();

      // Player submits their own workout result (once only)
      allow create: if isAuth()
                    && request.auth.uid == odId
                    && request.resource.data.userId == request.auth.uid
                    && isValidNumber(request.resource.data.formScore, 0, 100)
                    && isValidNumber(request.resource.data.reps, 0, 500)
                    && isValidString(request.resource.data.exercise, 100);

      // No updates or deletes — submissions are immutable
      allow update: if false;
      allow delete: if false;
    }


    // ══════════════════════════════════════════════════════════════
    // 4. GUILDS — Leader-only writes, member reads
    // ══════════════════════════════════════════════════════════════
    match /guilds/{guildId} {
      // Any authenticated user can browse guilds
      allow read: if isAuth();

      // Creating a guild: caller becomes the owner
      allow create: if isAuth()
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidString(request.resource.data.name, 50)
                    && request.resource.data.memberCount is number
                    && request.resource.data.memberCount <= 1;

      // Owner can update any guild fields (except server-only).
      // Any authenticated user can update ONLY memberIds + memberCount (join/leave).
      allow update: if (isAuth()
                        && resource.data.ownerId == request.auth.uid
                        && noServerFieldsOnUpdate())
                    || (isAuth()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['memberIds', 'memberCount']));

      // Only owner can delete
      allow delete: if isAuth()
                    && resource.data.ownerId == request.auth.uid;

      // ── Guild chat ──
      // Any guild member can read chat. Authors can create their own messages.
      // Only the message author can update/delete their own messages.
      match /chat/{messageId} {
        allow read: if isAuth();

        allow create: if isAuth()
                      && request.resource.data.userId == request.auth.uid
                      && isValidString(request.resource.data.message, 2000)
                      && request.resource.data.keys().size() <= 15;

        allow update: if isAuth()
                      && resource.data.userId == request.auth.uid;

        allow delete: if isAuth()
                      && resource.data.userId == request.auth.uid;
      }

      // ── Guild challenges — server-only ──
      // Weekly challenge data is written by scheduled Cloud Functions only
      match /challenges/{challengeId} {
        allow read: if isAuth();
        allow write: if false; // Server-only
      }

      // ── Guild War History — server-only ──
      // Weekly guild war results written by weeklyGuildWars function
      match /warHistory/{weekId} {
        allow read: if isAuth();
        allow write: if false; // Server-only
      }
    }


    // ══════════════════════════════════════════════════════════════
    // 5. GLOBAL SOCIAL — Chat, posts, feed
    // ══════════════════════════════════════════════════════════════

    // Global chat (locker room)
    match /global/data/chat/{messageId} {
      allow read: if isAuth();

      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && isValidString(request.resource.data.message, 2000)
                    && request.resource.data.keys().size() <= 15;

      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid;

      allow delete: if isAuth()
                    && resource.data.userId == request.auth.uid;
    }

    // Community posts
    match /global/data/posts/{postId} {
      allow read: if isAuth();

      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && isValidString(request.resource.data.userId, 128)
                    && request.resource.data.keys().size() <= 25;

      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid;

      allow delete: if isAuth()
                    && resource.data.userId == request.auth.uid;
    }

    // Activity feed — immutable, created by owner action
    match /global/data/feed/{feedId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Guild Leaderboard — server-only writes, any authenticated user can read
    match /global/data/guildLeaderboard/{guildId} {
      allow read: if isAuth();
      allow write: if false; // Server-only via weeklyGuildWars function
    }


    // ══════════════════════════════════════════════════════════════
    // 6. COMMUNITY BOSS — Server-authoritative
    // ══════════════════════════════════════════════════════════════
    // Boss creation, HP updates, and resets are ALL server-side.
    // Clients can only READ the boss state for display.
    // Damage is dealt via Cloud Function (prevents HP manipulation).
    match /community_boss/{docId} {
      allow read: if isAuth();
      allow write: if false; // Server-only via Admin SDK
    }


    // ══════════════════════════════════════════════════════════════
    // 7. TOURNAMENTS — Server-managed
    // ══════════════════════════════════════════════════════════════
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow create, update, delete: if false; // Server-only

      // Participants can join (create their own entry) and update their own
      match /participants/{participantId} {
        allow read: if isAuth();
        allow create: if isOwner(participantId);
        allow update: if isOwner(participantId);
        allow delete: if false;
      }
    }

    // Active tournament path
    match /global/tournament {
      allow read: if isAuth();
      allow write: if false; // Server-only
    }

    match /global/tournament/entries/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }


    // ══════════════════════════════════════════════════════════════
    // 8. WORKOUT TEMPLATES — Owner-only
    // ══════════════════════════════════════════════════════════════
    match /workoutTemplates/{templateId} {
      allow read: if isAuth()
                  && resource.data.userId == request.auth.uid;
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && hasReasonableFieldCount();
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && hasReasonableFieldCount();
      allow delete: if isAuth()
                    && resource.data.userId == request.auth.uid;
    }


    // ══════════════════════════════════════════════════════════════
    // 9. SUBSCRIPTIONS & ORDERS — Server-only writes
    // ══════════════════════════════════════════════════════════════
    match /subscriptions/{subId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Functions only
    }

    match /orders/{orderId} {
      allow read: if isAuth()
                  && resource.data.userId == request.auth.uid;
      allow write: if false; // Cloud Functions only
    }


    // ══════════════════════════════════════════════════════════════
    // 10. RATE LIMITS — Server-only
    // ══════════════════════════════════════════════════════════════
    match /rateLimits/{docId} {
      allow read, write: if false; // Internal — Cloud Functions only
    }


    // ══════════════════════════════════════════════════════════════
    // 11. AI CALL COUNTERS — Server-only
    // ══════════════════════════════════════════════════════════════
    // Daily free AI call tracking for non-premium users.
    // Reset by scheduled Cloud Function, incremented by callGemini.
    match /aiCallCounters/{userId} {
      allow read: if isOwner(userId); // Client can display remaining calls
      allow write: if false; // Server-only increments and resets
    }


    // ══════════════════════════════════════════════════════════════
    // 12. LEGACY ARTIFACTS — Owner-only
    // ══════════════════════════════════════════════════════════════
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }


    // ══════════════════════════════════════════════════════════════
    // DEFAULT DENY — Everything not explicitly matched above
    // ══════════════════════════════════════════════════════════════
    // No catch-all. Firestore denies any path not matched above.
  }
}
