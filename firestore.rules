rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Private user data ──
    // Only the owning user can read/write their own data.
    // Subscription and premium fields are SERVER-ONLY (Cloud Functions use Admin SDK).

    // Top-level user doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow writes but block subscription/isPremium fields from client
      allow create: if request.auth != null && request.auth.uid == userId
                    && !("subscription" in request.resource.data)
                    && !("isPremium" in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
                    && !("subscription" in request.resource.data.diff(resource.data).affectedKeys())
                    && !("isPremium" in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // User subcollections (data/profile, meals, workouts, etc.)
    match /users/{userId}/data/profile {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Block client writes to subscription/isPremium on profile too
      allow create: if request.auth != null && request.auth.uid == userId
                    && !("subscription" in request.resource.data)
                    && !("isPremium" in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
                    && !("subscription" in request.resource.data.diff(resource.data).affectedKeys())
                    && !("isPremium" in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Other user subcollections (meals, workouts, burned, progress, etc.)
    match /users/{userId}/data/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId
                         && docId != "profile"; // profile handled above
    }

    // Inbox — owner can read/update; any authenticated user can create (DMs)
    match /users/{userId}/inbox/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Any authenticated user can send a DM to this inbox
      allow create: if request.auth != null
                    && request.resource.data.fromId == request.auth.uid;
      // Owner can mark as read
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Following, notifications, photos — owner only
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId
                         && subcollection != "data"   // data handled above
                         && subcollection != "inbox";  // inbox handled above
    }

    // ── Leaderboard (top-level: leaderboard/{userId}) ──
    match /leaderboard/{entryId} {
      allow read: if request.auth != null;
      // Users can only write their own leaderboard entry
      allow write: if request.auth != null && request.auth.uid == entryId;
    }

    // ── Battles (top-level: battles/{battleId}) ──
    match /battles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.challenger.userId == request.auth.uid;
      // Only participants can update their battle
      allow update: if request.auth != null
                    && (resource.data.challenger.userId == request.auth.uid
                        || resource.data.opponent.userId == request.auth.uid);
      allow delete: if false;
    }

    // ── Global social collections ──
    match /global/data/chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    match /global/data/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    match /global/data/feed/{feedId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Feed entries are immutable
    }

    // ── Community Boss (community_boss/current) ──
    match /community_boss/{docId} {
      allow read: if request.auth != null;
      // Users can update boss damage (Cloud Functions handle resets)
      allow update: if request.auth != null;
      // Only server creates bosses
      allow create, delete: if false;
    }

    // ── Tournaments (legacy top-level structure) ──
    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      // Only server creates/manages tournaments
      allow create, update, delete: if false;

      // Participants — users can join (create) and update their own entry
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.auth.uid == participantId;
        allow update: if request.auth != null
                      && request.auth.uid == participantId;
        allow delete: if false;
      }
    }

    // ── Tournament (active path: global/tournament + entries subcollection) ──
    match /global/tournament {
      allow read: if request.auth != null;
      // Only server creates/manages the tournament doc
      allow create, update, delete: if false;
    }

    match /global/tournament/entries/{userId} {
      allow read: if request.auth != null;
      // Users can create/update their own entry
      allow create: if request.auth != null
                    && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Workout Templates ──
    match /workoutTemplates/{templateId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ── Guilds ──
    match /guilds/{guildId} {
      allow read: if request.auth != null;
      // Any authenticated user can create a guild (they become owner)
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      // Owner can update anything; members can only update members/memberCount (join/leave)
      allow update: if request.auth != null
                    && (resource.data.ownerId == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['members', 'memberCount']));
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      // Guild chat — authenticated members can read; only message author can write
      match /chat/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
                              && resource.data.userId == request.auth.uid;
      }
    }

    // ── Subscriptions (read-only from client, writes through Cloud Functions) ──
    match /subscriptions/{subId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Legacy artifacts structure ──
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
