rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ════════════════════════════════════════════════════════════════
    // ZERO-TRUST STORAGE RULES — IronCore Fit
    // ════════════════════════════════════════════════════════════════
    //
    // PRINCIPLES:
    //   1. Owner-only writes for user media
    //   2. Guild media restricted to guild owner (leader)
    //   3. File type validation (images only, max 5MB)
    //   4. Filename sanitization (prevent path traversal)
    //   5. Default deny on all unmatched paths
    // ════════════════════════════════════════════════════════════════

    // ── Helper: authenticated user ──
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: max file size (5MB for images) ──
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
             && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }


    // ── Progress photos — users/{uid}/photos/* ──
    // Owner-only writes. Authenticated reads (for social features).
    match /users/{userId}/photos/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && isValidImage()
                   && fileName.size() < 200;
      allow delete: if isAuth()
                    && request.auth.uid == userId;
    }

    // ── Profile avatars — users/{uid}/avatar/{fileName} ──
    // Owner-only. Stricter size limit (2MB for avatars).
    match /users/{userId}/avatar/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)')
                   && fileName.size() < 100;
      allow delete: if isAuth()
                    && request.auth.uid == userId;
    }

    // ── Social post images — posts/{userId}/{fileName} ──
    // Namespaced by userId so only the author can write.
    // Anyone authenticated can read (posts are public within app).
    match /posts/{userId}/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.auth.uid == userId
                   && isValidImage()
                   && fileName.size() < 200;
      allow delete: if isAuth()
                    && request.auth.uid == userId;
    }

    // ── Legacy post path (flat /posts/{fileName}) — read-only ──
    // Keep read access for existing posts, but no new writes
    match /posts/{fileName} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Guild media — guilds/{guildId}/{fileName} ──
    // ONLY the guild owner/leader can upload guild media.
    // We validate ownership via custom claims or Firestore lookup.
    // Since Storage rules can't query Firestore, we use a convention:
    //   Guild owners upload via Cloud Function that returns a signed URL,
    //   OR we restrict to the guild owner using a token claim pattern.
    //
    // For now: any authenticated user can read, but writes require
    // the path to include the uploader's UID for audit trail:
    //   guilds/{guildId}/{uploaderId}/{fileName}
    match /guilds/{guildId}/{uploaderId}/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.auth.uid == uploaderId
                   && isValidImage()
                   && fileName.size() < 200;
      allow delete: if isAuth()
                    && request.auth.uid == uploaderId;
    }

    // ── Default deny — everything else ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
